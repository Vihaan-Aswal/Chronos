# ----------------------------------------------------
# SUPABASE AUTH
# ----------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------
# BACKEND REST + WEBSOCKET
# ----------------------------------------------------
# HTTP base URL (use your deployed backend URL in production)
VITE_BACKEND_URL=http://localhost:8000

# WebSocket base URL - MUST use wss:// in production (e.g. wss://your-backend.railway.app)
VITE_BACKEND_WS_URL=ws://localhost:8000

# ----------------------------------------------------
# 100ms (HMS) - optional token endpoint
# ----------------------------------------------------
VITE_HMS_TOKEN_ENDPOINT=http://localhost:8000/hms-token
VITE_HMS_ENV=dev
